{
  "name": "pyxis-components",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./tokens": "./dist/tokens/index.js",
    "./theme": "./dist/theme/index.js",
    "./mocks/handlers": {
      "import": "./src/mocks/handlers.ts",
      "types": "./src/mocks/handlers.ts"
    },
    "./mocks/types": {
      "import": "./src/mocks/types.ts",
      "types": "./src/mocks/types.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build && tsc -p tsconfig.build.json",
    "build:watch": "tsc -p tsconfig.build.json --watch && vite build --watch",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write src --ext .ts,.tsx",
    "clean": "rm -rf dist storybook-static"
  },
  "peerDependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.3.6",
    "@storybook/addon-essentials": "^8.0.0",
    "@storybook/addon-interactions": "^8.0.0",
    "@storybook/react": "^10.3.6",
    "@storybook/react-vite": "^10.3.6",
    "@storybook/test": "^8.6.18",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-config-prettier": "^10.0.0",
    "identity-obj-proxy": "^3.0.0",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "msw-storybook-addon": "^2.0.0",
    "prettier": "^3.2.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "storybook": "^10.3.6",
    "typescript": "^6.0.3",
    "vite": "^8.0.12",
    "vite-plugin-dts": "^5.0.0",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "clsx": "^2.1.0",
    "pyxis-types": "workspace:*"
  }
}
