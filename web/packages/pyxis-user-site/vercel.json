{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm --filter pyxis-user-site build",
  "devCommand": "pnpm --filter pyxis-user-site dev",
  "installCommand": "pnpm install",
  "framework": null,
  "builds": [
    {
      "src": "packages/pyxis-user-site/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "regions": ["iad1"],
  "env": {
    "VITE_API_URL": "@pyxis_api_url"
  }
}
